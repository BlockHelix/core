# Clerk auth (create an app at https://dashboard.clerk.com)
# Placeholder pk below keeps `npm run build` green without a real Clerk app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_Y2xlcmsuZXhhbXBsZS5jb20k
CLERK_SECRET_KEY=sk_test_your_secret_key

# Vault-factory API (server-side only — the key must NEVER be exposed to the browser)
VAULT_API_URL=https://api.blockhelix.tech
VAULT_API_KEY=your_vault_factory_api_key

# Base RPC (Alchemy) — used server-side to read live vault state AND the activity
# feed (alchemy_getAssetTransfers). Point this at your Alchemy Base endpoint;
# a plain public RPC works for state but not the transfer feed.
NEXT_PUBLIC_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_alchemy_key

# ETHERSCAN_API_KEY — no longer used by the app (Etherscan V2 free tier doesn't
# cover Base). Activity now runs off the Alchemy RPC. Kept for reference only.
# ETHERSCAN_API_KEY=

# Reown (WalletConnect) project id — REQUIRED for the /admin wallet connect.
# Create a project at https://dashboard.reown.com. Client-exposed (public) by design.
# Without a real id the admin Connect Wallet / WalletConnect flow will not work.
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id

# Waitlist (existing)
# RESEND_API_KEY=
# RESEND_AUDIENCE_ID=

# Analytics (existing)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Solana on-chain verify script (npm run verify) — legacy, not used by the web app
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_NETWORK=devnet
